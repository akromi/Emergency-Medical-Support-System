# Copy to `.env` and adjust before `docker compose up`. All values have safe
# local defaults; override the DB credentials and set the API tokens for any
# shared-LAN deployment.

# --- Postgres (local, persisted in the `pgdata` volume) ---
POSTGRES_USER=triagelink
POSTGRES_PASSWORD=change-me
POSTGRES_DB=triagelink

# --- App ---
# Host port the PWA + API are published on (http://<laptop-ip>:APP_PORT).
APP_PORT=8080

# Bearer token required on /sync and /ehr/* (leave blank = unauthenticated,
# fine for a single trusted device; set it when several devices share the LAN).
SYNC_API_TOKEN=

# Bearer token for the tenant-admin API (/admin/*) and, with the line below,
# the graphical admin console at /console.
SYNC_ADMIN_TOKEN=
ENABLE_ADMIN_CONSOLE=false

# Extra browser origins allowed to call the API. Empty is correct for the
# bundled same-origin app; only needed if a separate PWA origin syncs here.
CORS_ORIGINS=
