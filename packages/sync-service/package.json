{
  "name": "@triage-link/sync-service",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify + PostgreSQL conflict-aware sync service for TRIAGE-LINK casualty records",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "start": "node --experimental-strip-types src/server.ts",
    "dev": "tsx src/dev-server.ts",
    "openapi:export": "tsx src/export-openapi.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@triage-link/core": "*",
    "@triage-link/ehr-gateway": "*",
    "fastify": "^5.8.5",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "pg-mem": "^3.0.5",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
