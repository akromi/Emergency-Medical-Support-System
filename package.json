{
  "name": "triage-link",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Offline-first PWA for casualty care & transport documentation",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "core:build": "npm run build --workspace @triage-link/core",
    "predev": "npm run core:build",
    "dev": "vite",
    "prebuild": "npm run core:build",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "pretypecheck": "npm run core:build",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run core:build",
    "test": "npm run test --workspaces --if-present && npm run test:app",
    "test:app": "vitest run",
    "test:ui": "npm run core:build && vitest --ui --config vitest.all.config.ts",
    "test:report": "npm run core:build && vitest run --config vitest.report.config.ts",
    "test:e2e": "playwright test",
    "check": "npm run typecheck && npm run typecheck --workspaces --if-present && npm test && npm run build",
    "sync": "git pull origin main && npm install"
  },
  "dependencies": {
    "@triage-link/core": "*",
    "@triage-link/ehr-gateway": "*",
    "dexie": "^4.0.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.9",
    "axe-core": "^4.12.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
